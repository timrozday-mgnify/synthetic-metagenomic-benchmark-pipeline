// Container engine is chosen at invocation via `--profile docker` (real/e2e
// tests). With no profile, tasks run on the host — stub tests need no images.
process {
    resourceLimits = [cpus: 4, memory: '8.GB', time: '1.h']
}

params {
    test_data_base = "${projectDir}/tests/data/"

    // Deterministic, fast error-model fit on tiny fixtures: a single small model,
    // no AIC search.
    error_model_components = 'AdditiveContext(3)'
}

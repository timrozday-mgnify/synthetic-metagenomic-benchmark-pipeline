nextflow_pipeline {
    name "Test Pipeline SYNTHETIC_METAGENOMIC_BENCHMARK"
    script "main.nf"

    tag "pipeline"

    test("two synthetic samples - stub") {
        tag "stub"
        options "-stub"
        when {
            params {
                input  = "${projectDir}/tests/samplesheets/test.yaml"
                outdir = "$outputDir"
            }
        }
        then {
            assertAll(
                { assert workflow.success },
                // 2 samples share train_id natA -> train once. S1 fans out over
                // 2 subsample runs (none + 500), S2 over 1 (none). So:
                // 1 SEQKIT_SUBSAMPLE_TRAIN + 1 SKIVER_DUMP + 1 SKIVER_TRAIN + 1 SKIVER_REPORT
                // + 2 NORMALISE_REFERENCES + 2 GENOME_BLENDER_GENERATE + 3 SEQKIT_SUBSAMPLE + 3 GROUND_TRUTH = 14
                { assert workflow.trace.succeeded().size() == 14 }
            )
        }
    }

    test("chunked generation - stub") {
        tag "stub"
        options "-stub"
        when {
            params {
                input  = "${projectDir}/tests/samplesheets/chunks.yaml"
                outdir = "$outputDir"
            }
        }
        then {
            assertAll(
                { assert workflow.success },
                // S1 with chunks:3, no subsample: 1 subsample_train + 1 dump + 1 train + 1 report
                // + 1 NORMALISE_REFERENCES + 3 GENOME_BLENDER_GENERATE + 1 MERGE_GENOME_BLENDER_CHUNKS
                // + 1 SEQKIT_SUBSAMPLE + 1 GROUND_TRUTH = 11
                { assert workflow.trace.succeeded().size() == 11 },
                { assert path("${params.outdir}/S1/S1_R1.fastq.gz").exists() },
                { assert path("${params.outdir}/S1/S1.truth.tsv").exists() }
            )
        }
    }

    test("generate + sylph self profiling - stub") {
        tag "stub"
        options "-stub"
        when {
            params {
                input  = "${projectDir}/tests/samplesheets/profiling.yaml"
                outdir = "$outputDir"
            }
        }
        then {
            assertAll(
                { assert workflow.success },
                // 12 generation tasks (subsample_train + dump + train + report
                // + 2 NORMALISE_REFERENCES + 2 gen + 2 subsample + 2 truth)
                // + per sample: SYLPH_BUILD_DB + SYLPH_PROFILE + NORMALIZE_SYLPH
                // = 3*2 = 6 profiling tasks = 18.
                { assert workflow.trace.succeeded().size() == 18 },
                { assert path("${params.outdir}/S1/S1.sylph_profile.tsv").exists() },
                { assert path("${params.outdir}/S2/S2.sylph_profile.tsv").exists() }
            )
        }
    }

    test("built + prebuilt profiler databases - stub") {
        tag "stub"
        options "-stub"
        when {
            params {
                input  = "${projectDir}/tests/samplesheets/databases.yaml"
                outdir = "$outputDir"
            }
        }
        then {
            assertAll(
                { assert workflow.success },

                // Built DBs published under databases/<name>/ (the prebuilt-dir layout).
                { assert path("${params.outdir}/databases/commA/commA.syldb").exists() },
                { assert path("${params.outdir}/databases/ampA/ampA.mapseq.fasta").exists() },
                { assert path("${params.outdir}/databases/ampA/ampA.mapseq.tax").exists() },
                { assert path("${params.outdir}/databases/ampA/ampA.mapseq.otu").exists() },

                // S1 profiled against the built sylph DB; S3 against the pre-built dir.
                { assert path("${params.outdir}/S1/S1.sylph_profile.tsv").exists() },
                { assert path("${params.outdir}/S3/S3.sylph_profile.tsv").exists() },

                // S2 profiled via aap against the built mapseq DB.
                { assert path("${params.outdir}/S2/profiling/aap").exists() }
            )
        }
    }

    test("train-only - stub") {
        tag "stub"
        options "-stub"
        when {
            params {
                input  = "${projectDir}/tests/samplesheets/train.yaml"
                outdir = "$outputDir"
                step   = "train"
            }
        }
        then {
            assertAll(
                { assert workflow.success },
                // train-only: 1 SEQKIT_SUBSAMPLE_TRAIN + 1 SKIVER_DUMP + 1 SKIVER_TRAIN
                // + 1 SKIVER_REPORT = 4. No generation/profiling.
                { assert workflow.trace.succeeded().size() == 4 },
                { assert path("${params.outdir}/error_models/natA/natA.model.pt").exists() }
            )
        }
    }

    test("generate with pre-trained error_model_dir - stub") {
        tag "stub"
        options "-stub"
        when {
            params {
                input  = "${projectDir}/tests/samplesheets/pretrained.yaml"
                outdir = "$outputDir"
                step   = "generate"
            }
        }
        then {
            assertAll(
                { assert workflow.success },
                // No training for natA (model comes from error_model_dir):
                // 1 NORMALISE_REFERENCES + 1 GENOME_BLENDER_GENERATE + 1 SEQKIT_SUBSAMPLE + 1 GROUND_TRUTH = 4.
                { assert workflow.trace.succeeded().size() == 4 },
                { assert workflow.trace.tasks().every { !it.name.contains('SKIVER_TRAIN') } },
                { assert path("${params.outdir}/S1/S1_R1.fastq.gz").exists() }
            )
        }
    }

    test("profile-only aap - stub") {
        tag "stub"
        options "-stub"
        when {
            params {
                input  = "${projectDir}/tests/samplesheets/profile.yaml"
                outdir = "$outputDir"
                step   = "profile"
            }
        }
        then {
            assertAll(
                { assert workflow.success },
                // profile-only: no generation, just 1 RUN_AAP.
                { assert workflow.trace.succeeded().size() == 1 }
            )
        }
    }

    test("two synthetic samples") {
        tag "e2e"
        when {
            params {
                input  = "${projectDir}/tests/samplesheets/test.yaml"
                outdir = "$outputDir"
            }
        }
        then {
            assertAll(
                { assert workflow.success },

                // Reads (paired) per sample
                { assert path("${params.outdir}/S1/S1_R1.fastq.gz").exists() },
                { assert path("${params.outdir}/S1/S1_R2.fastq.gz").exists() },
                { assert path("${params.outdir}/S2/S2_R1.fastq.gz").exists() },

                // S1's 500-read subsample gets its own dir with its own reads + truth
                { assert path("${params.outdir}/S1/subsample_500/S1_R1.fastq.gz").exists() },
                { assert path("${params.outdir}/S1/subsample_500/S1.sub500.truth.tsv").exists() },

                // Ground-truth BAM + index
                { assert path("${params.outdir}/S1/S1.sorted.bam").exists() },
                { assert path("${params.outdir}/S1/S1.sorted.bam.bai").exists() },

                // Ground-truth profile with both genomes + 4 columns
                { assert path("${params.outdir}/S1/S1.truth.tsv").exists() },
                { assert path("${params.outdir}/S1/S1.truth.tsv").text.contains("genomeA") },
                { assert path("${params.outdir}/S1/S1.truth.tsv").text.contains("genomeB") },
                { assert path("${params.outdir}/S1/S1.truth.tsv").readLines().get(0)
                    == "genome_id\ttarget_rel_abundance\trealized_n_reads\trealized_rel_abundance" },

                // Trained model shared by both samples (train once)
                { assert path("${params.outdir}/error_models/natA/natA.model.pt").exists() },
                { assert path("${params.outdir}/error_models/natA/natA.phred_calibration.json").exists() },
                { assert path("${params.outdir}/error_models/natA/natA.error_model_report.html").exists() },

                // train_subsample: 1000 -> training reads published at 1000 reads (4000 lines), not the full 6000
                { assert path("${params.outdir}/error_models/natA/training_reads/natural_R1.fastq.gz").exists() },
                { assert path("${params.outdir}/error_models/natA/training_reads/natural_R1.fastq.gz").linesGzip.size() == 4000 }
            )
        }
    }

    test("chunked generation - unique read ids + cat merge") {
        tag "e2e"
        // Real (non-stub) chunked run: S1 fans out over 3 chunks, each with a
        // distinct --read-prefix, then MERGE_GENOME_BLENDER_CHUNKS concatenates
        // the per-chunk BAMs with `samtools cat`. Verifies the read-name
        // uniqueness fix (no colliding IDs once chunks are merged) and that the
        // cat-merged BAM is valid (GROUND_TRUTH sorts + indexes it downstream).
        when {
            params {
                input  = "${projectDir}/tests/samplesheets/chunks.yaml"
                outdir = "$outputDir"
            }
        }
        then {
            // Read IDs from the merged R1 FASTQ (concatenation of all 3 chunks).
            def headers = path("${params.outdir}/S1/S1_R1.fastq.gz").linesGzip
                .withIndex().findAll { line, i -> i % 4 == 0 }.collect { line, i -> line }
            def ids = headers.collect { it.split(/\s/)[0] }          // up to first space
            def prefixes = ids.collect { it.replaceFirst(/^@/, '').split(':')[0] }

            assertAll(
                { assert workflow.success },

                // Merged reads + cat-merged, sorted, indexed ground-truth BAM.
                { assert path("${params.outdir}/S1/S1_R1.fastq.gz").exists() },
                { assert path("${params.outdir}/S1/S1_R2.fastq.gz").exists() },
                { assert path("${params.outdir}/S1/S1.sorted.bam").exists() },
                { assert path("${params.outdir}/S1/S1.sorted.bam.bai").exists() },
                { assert path("${params.outdir}/S1/S1.truth.tsv").exists() },

                // Core fix: no colliding read IDs across the merged chunks.
                { assert ids.size() > 0 },
                { assert (ids as Set).size() == ids.size() },

                // --read-prefix wiring: every read is namespaced by its chunk,
                // and reads actually came from more than one chunk.
                { assert prefixes.every { it.startsWith('S1.chunk') } },
                { assert (prefixes as Set).size() >= 2 }
            )
        }
    }

    test("generate + sylph self profiling") {
        tag "e2e"
        when {
            params {
                input  = "${projectDir}/tests/samplesheets/profiling.yaml"
                outdir = "$outputDir"
            }
        }
        then {
            assertAll(
                { assert workflow.success },

                // Generation + ground truth still produced.
                { assert path("${params.outdir}/S1/S1_R1.fastq.gz").exists() },
                { assert path("${params.outdir}/S1/S1.truth.tsv").exists() },

                // Predicted sylph profile lands next to truth.tsv, with the right header.
                { assert path("${params.outdir}/S1/S1.sylph_profile.tsv").exists() },
                { assert path("${params.outdir}/S2/S2.sylph_profile.tsv").exists() },
                { assert path("${params.outdir}/S1/S1.sylph_profile.tsv").readLines().get(0)
                    == "genome_id\tpredicted_rel_abundance\tpredicted_tax_rel_abundance" },

                // Raw sylph output kept under profiling/.
                { assert path("${params.outdir}/S1/profiling/sylph/S1.sylph.tsv").exists() }
            )
        }
    }

    test("profile-only sylph, configured db") {
        tag "e2e"
        // Uses a committed .syldb fixture (tests/data/refdb.syldb, built with
        // `sylph sketch -g genomeA.fasta genomeB.fasta -o refdb`) as a configured
        // (non-self) database, exercising the step=profile + params.sylph_databases path.
        when {
            params {
                input           = "${projectDir}/tests/samplesheets/profile_sylph.yaml"
                outdir          = "$outputDir"
                step            = "profile"
                sylph_databases = [ refdb: [ syldb: "${projectDir}/tests/data/refdb.syldb", label: "refdb" ] ]
            }
        }
        then {
            assertAll(
                { assert workflow.success },
                { assert path("${params.outdir}/P1/P1.sylph_profile.tsv").exists() },
                { assert path("${params.outdir}/P1/P1.sylph_profile.tsv").readLines().get(0)
                    == "genome_id\tpredicted_rel_abundance\tpredicted_tax_rel_abundance" }
            )
        }
    }
}

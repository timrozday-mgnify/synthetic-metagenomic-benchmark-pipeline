nextflow_process {
    name "Test Process MAPSEQ_CLUSTER"
    script "../main.nf"
    process "MAPSEQ_CLUSTER"

    tag "modules"
    tag "mapseq"
    tag "mapseq/build_db"

    test("cluster mapseq db - stub") {
        tag "stub"
        options "-stub"
        when {
            process {
                """
                input[0] = [
                    [ id:'ampA' ],
                    file(params.test_data_base + 'genomeA.fasta', checkIfExists: true),
                    file(params.test_data_base + 'genomeB.fasta', checkIfExists: true)
                ]
                """
            }
        }
        then {
            assertAll(
                { assert process.success },
                { assert process.out.mscluster.size() == 1 },
                { assert snapshot(process.out.findAll { k, v -> k.startsWith("versions") }).match() }
            )
        }
    }
}

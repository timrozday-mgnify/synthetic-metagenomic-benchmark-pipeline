nextflow_process {
    name "Test Process NORMALISE_REFERENCES"
    script "../main.nf"
    process "NORMALISE_REFERENCES"

    tag "modules"
    tag "normalise_references"

    test("normalise references - stub") {
        tag "stub"
        options "-stub"
        when {
            process {
                """
                input[0] = [
                    [ id:'S1' ],
                    file(params.test_data_base + 'genomes_S1.csv', checkIfExists: true),
                    [
                        file(params.test_data_base + 'genomeA.fasta', checkIfExists: true),
                        file(params.test_data_base + 'genomeB.fasta', checkIfExists: true)
                    ]
                ]
                """
            }
        }
        then {
            assertAll(
                { assert process.success },
                { assert process.out.references.get(0).get(2).size() == 2 },
                { assert process.out.mappings.get(0).get(1).size() == 2 }
            )
        }
    }
}

params {
    // Required
    input            = null   // samplesheet (YAML list of sample maps)
    outdir           = './results'

    // Run mode: 'all' (generate + profile) | 'generate' | 'profile'
    step             = 'all'

    // Publishing
    publish_dir_mode = 'copy'
    // Ground-truth BAMs omit read SEQ/QUAL (written as '*'). Truth tables only
    // need read names + reference, so this shrinks every BAM ~10-1000x. Set
    // false to keep full SEQ/QUAL alignments.
    slim_bam         = true

    // Taxonomic profiling ------------------------------------------------------
    // sylph (WGS): named databases, mapseq_databases-style. Each entry needs a
    // prebuilt .syldb. The reserved value 'self' builds the DB from the sample's
    // own reference genomes (exact-match benchmark). Select per-sample via the
    // `database` samplesheet column.
    //   sylph_databases = [ gtdb_r220: [ syldb: '/dbs/gtdb.syldb', label: 'GTDB-r220' ] ]
    sylph_databases  = [:]

    // amplicon-analysis-pipeline (amplicon): run via nested `nextflow run`.
    aap_revision     = 'main'    // -r for ebi-metagenomics/amplicon-analysis-pipeline
    aap_profile      = 'docker'  // -profile for the nested run
    aap_config       = null      // extra -c config (carries mapseq_databases etc.)

    // Reproducibility
    seed             = 42

    // Read geometry (per-sample overridable via samplesheet columns of the same name)
    paired_end           = true    // legacy default was mode=paired
    read_length_mean     = 150     // genome-blender default
    read_length_variance = 10      // genome-blender default

    // Error-model training
    // Candidate component strings fitted by skiver; the min-AIC model is kept.
    error_model_candidates = 'AdditiveContext(5),AdditiveContext(7),AdditiveContext(9)'
    // Override: force a single component string (skips AIC selection over candidates).
    error_model_components = null

    // Container image tags (images built + pushed by .github/workflows/build-images.yml)
    smb_skiver_tag         = 'latest'
    smb_genome_blender_tag = 'latest'

    // Resource limits (overridden by HPC/cloud profiles)
    max_cpus         = 16
    max_memory       = '128.GB'
    max_time         = '240.h'
}

includeConfig 'conf/base.config'
includeConfig 'conf/modules.config'

profiles {
    docker {
        docker.enabled    = true
        docker.runOptions = '-u $(id -u):$(id -g)'
    }
    singularity {
        singularity.enabled    = true
        singularity.autoMounts = true
    }
    apptainer {
        apptainer.enabled    = true
        apptainer.autoMounts = true
    }
}

manifest {
    name            = 'synthetic-metagenomic-benchmark-pipeline'
    description     = 'Train a sequencing error profile from natural metagenomes and generate synthetic metagenomes with ground-truth mapping + profile'
    version         = '0.1.0'
    nextflowVersion = '>=25.0'
}

trace {
    enabled   = true
    file      = "${params.outdir}/pipeline_info/execution_trace_${new Date().format('yyyy-MM-dd_HH-mm-ss')}.txt"
    overwrite = false
}

report {
    enabled   = true
    file      = "${params.outdir}/pipeline_info/execution_report_${new Date().format('yyyy-MM-dd_HH-mm-ss')}.html"
    overwrite = false
}

timeline {
    enabled   = true
    file      = "${params.outdir}/pipeline_info/execution_timeline_${new Date().format('yyyy-MM-dd_HH-mm-ss')}.html"
    overwrite = false
}

dag {
    enabled   = true
    file      = "${params.outdir}/pipeline_info/pipeline_dag_${new Date().format('yyyy-MM-dd_HH-mm-ss')}.html"
    overwrite = false
}

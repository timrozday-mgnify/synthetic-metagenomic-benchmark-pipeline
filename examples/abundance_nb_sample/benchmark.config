// Overrides for the negative-binomial abundance-sample benchmark.
// Read geometry lives in the samplesheet columns (mode, paired_end,
// read_length_mean, read_length_variance), not ext.args.
params {
    seed = 42
    // Force a single context model instead of the AIC search if you prefer:
    // error_model_components = 'AdditiveContext(7)'

    // Custom PIMENTO primer library for the nested amplicon-analysis-pipeline
    // (forwarded as --std_primer_library). Vendored copy of PIMENTO's standard
    // primers, which already cover all 5 generation primer pairs in config.yaml
    // by sequence, so PIMENTO matches known primers instead of its bundled set.
    aap_std_primer_library = "${projectDir}/examples/abundance_nb_sample/pimento_primers"

    // HPC: the nested amplicon-analysis-pipeline runs on the host and does NOT
    // inherit the outer -profile. Point it at an engine config here (and switch
    // run.sh's `-profile docker` to `-profile singularity`):
    // aap_configs = ['/path/to/aap_singularity.config']   // { singularity.enabled = true; singularity.autoMounts = true }
}

// Overrides for the sub-species V4 amplicon sweep.
// Amplicon mode maps only to genome-blender `--amplicon` (single-end, 150 bp default),
// so paired 2x300 reads over the ~253 bp V4 amplicon are set here via ext.args.
params {
    seed = 42
    // 2x300 amplicon: force a single context model instead of the AIC search if you prefer:
    // error_model_components = 'AdditiveContext(7)'
}

process {
    withName: GENOME_BLENDER_GENERATE {
        ext.args = '--paired-end --read-length-mean 300 --read-length-variance 0'
    }
}

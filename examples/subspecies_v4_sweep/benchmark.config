// Overrides for the sub-species V4 amplicon sweep.
// Read geometry (paired 2x300 over the ~253 bp V4 amplicon) now lives in the
// samplesheet columns (mode, paired_end, read_length_mean, read_length_variance),
// not ext.args.
params {
    seed = 42
    // 2x300 amplicon: force a single context model instead of the AIC search if you prefer:
    // error_model_components = 'AdditiveContext(7)'

    // HPC: the nested amplicon-analysis-pipeline runs on the host and does NOT
    // inherit the outer -profile. Point it at an engine config here (and switch
    // run.sh's `-profile docker` to `-profile singularity`):
    // aap_configs = ['/path/to/aap_singularity.config']   // { singularity.enabled = true; singularity.autoMounts = true }
}

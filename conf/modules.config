// Default: don't publish anything (modules opt in explicitly below).
process {
    publishDir = [ enabled: false ]

    withName: 'SKIVER_TRAIN' {
        // Publish the trained model + calibration + AIC table once per train_id.
        publishDir = [
            path: { "${params.outdir}/error_models/${meta.id}" },
            mode: params.publish_dir_mode,
            saveAs: { fn -> fn.equals('versions.yml') ? null : fn }
        ]
    }

    withName: 'GENOME_BLENDER_GENERATE' {
        publishDir = [
            path: { "${params.outdir}/${meta.id}" },
            mode: params.publish_dir_mode,
            pattern: '*.fastq.gz'
        ]
    }

    withName: 'GROUND_TRUTH' {
        publishDir = [
            path: { "${params.outdir}/${meta.id}" },
            mode: params.publish_dir_mode,
            saveAs: { fn -> fn.equals('versions.yml') ? null : fn }
        ]
    }
}

// Default: don't publish anything (modules opt in explicitly below).
//
// Each generate run publishes into ${outdir}/${meta.sample}[/subsample_<N>] so a
// full-depth run lands next to its truth.tsv and each subsample gets its own dir.
process {
    publishDir = [ enabled: false ]

    // In-silico PCR: publish the raw AmpliconHunter outputs (amplicons.fa,
    // run_statistics.json, plots) under each primer pair's own output tree.
    // meta.id = "<sample>.<pair>", matching where that pair's reads + truth land.
    withName: 'AMPLICONHUNTER' {
        ext.args   = params.ampliconhunter_args
        // Fixed output-dir name so results land in ${meta.id}/ampliconhunter/ (not
        // ${meta.id}/ampliconhunter/${meta.id}/).
        ext.prefix = 'ampliconhunter'
        publishDir = [
            path: { "${params.outdir}/${meta.id}" },
            mode: params.publish_dir_mode,
            saveAs: { fn -> fn.equals('versions.yml') ? null : fn }
        ]
    }

    withName: 'SKIVER_TRAIN' {
        // Publish the trained model + calibration + AIC table once per train_id.
        publishDir = [
            path: { "${params.outdir}/error_models/${meta.id}" },
            mode: params.publish_dir_mode,
            saveAs: { fn -> fn.equals('versions.yml') ? null : fn }
        ]
    }

    // Training reads actually fed to SKIVER_DUMP (post train_subsample, or the
    // full set when unset), published alongside the trained model for audit.
    withName: 'SEQKIT_SUBSAMPLE_TRAIN' {
        publishDir = [
            path: { "${params.outdir}/error_models/${meta.id}" },
            mode: params.publish_dir_mode,
            pattern: 'sub_*',
            saveAs: { fn -> fn.startsWith('sub_') ? "training_reads/${fn.substring(4)}" : null }
        ]
    }

    withName: 'SKIVER_REPORT' {
        // Human-readable HTML summary, alongside the raw model/AIC/calibration files.
        publishDir = [
            path: { "${params.outdir}/error_models/${meta.id}" },
            mode: params.publish_dir_mode,
            saveAs: { fn -> fn.equals('versions.yml') ? null : fn }
        ]
    }

    // Subsampled (or full-depth passthrough) reads for this run.
    withName: 'SEQKIT_SUBSAMPLE' {
        publishDir = [
            path: { meta.publish_subdir ? "${params.outdir}/${meta.sample}/${meta.publish_subdir}" : "${params.outdir}/${meta.sample}" },
            mode: params.publish_dir_mode,
            pattern: 'sub_*',
            // Strip the work-dir `sub_` guard prefix from published read names.
            saveAs: { fn -> fn.startsWith('sub_') ? fn.substring(4) : null }
        ]
    }

    withName: 'GROUND_TRUTH' {
        publishDir = [
            path: { meta.publish_subdir ? "${params.outdir}/${meta.sample}/${meta.publish_subdir}" : "${params.outdir}/${meta.sample}" },
            mode: params.publish_dir_mode,
            saveAs: { fn -> fn.equals('versions.yml') ? null : fn }
        ]
    }

    // --- Profiler databases ---
    // Built named-collection DBs land in ${outdir}/databases/<name>/. This is the
    // exact layout a `databases: { <name>: { path: ... } }` prebuilt entry expects,
    // so a databases/<name>/ dir from a prior run is directly reusable.
    withName: 'SYLPH_BUILD_COLLECTION' {
        publishDir = [
            path: { "${params.outdir}/databases/${meta.id}" },
            mode: params.publish_dir_mode,
            pattern: '*.syldb'
        ]
    }
    withName: 'MAPSEQ_PREP' {
        publishDir = [
            path: { "${params.outdir}/databases/${meta.id}" },
            mode: params.publish_dir_mode,
            pattern: '*.mapseq.{fasta,tax}'
        ]
    }
    withName: 'MAPSEQ_CLUSTER' {
        publishDir = [
            path: { "${params.outdir}/databases/${meta.id}" },
            mode: params.publish_dir_mode,
            pattern: '*.mscluster'
        ]
    }
    withName: 'MAPSEQ_OTU' {
        publishDir = [
            path: { "${params.outdir}/databases/${meta.id}" },
            mode: params.publish_dir_mode,
            pattern: '*.mapseq.otu'
        ]
    }

    // --- Profiling ---

    // Normalised sylph profile lands next to truth.tsv for easy comparison.
    withName: 'NORMALIZE_SYLPH' {
        publishDir = [
            path: { meta.publish_subdir ? "${params.outdir}/${meta.sample}/${meta.publish_subdir}" : "${params.outdir}/${meta.sample}" },
            mode: params.publish_dir_mode,
            pattern: '*.sylph_profile.tsv'
        ]
    }

    // Raw sylph output kept under a profiling/ subdir.
    withName: 'SYLPH_PROFILE' {
        publishDir = [
            path: { meta.publish_subdir ? "${params.outdir}/${meta.sample}/${meta.publish_subdir}/profiling/sylph" : "${params.outdir}/${meta.sample}/profiling/sylph" },
            mode: params.publish_dir_mode,
            pattern: '*.sylph.tsv'
        ]
    }

    // Amplicon-analysis-pipeline outputs under a profiling/ subdir. RUN_AAP is batched
    // (many samples per task), so the destination is derived per file from AAP's
    // aap_out/<id>/... layout, mapping <id> back to that sample's publish dir via `metas`.
    // Study-level aggregates (aap_out/<x> with no sample match, or top-level files) are dropped.
    withName: 'RUN_AAP' {
        publishDir = [
            path: { params.outdir },
            mode: params.publish_dir_mode,
            saveAs: { fn ->
                def mm = (fn =~ '^aap_out/([^/]+)/(.*)$')
                if (!mm) return null
                def id = mm[0][1]
                def rest = mm[0][2]
                // Only the mapseq taxonomy-summary output feeds the benchmark reports;
                // drop the bulky diagnostics (sequence-categorisation, amplified-region-
                // inference, qc merged fastq/multiqc, asv, primers, study-level files).
                if (!rest.startsWith('taxonomy-summary/')) return null
                def s = metas.find { it.id == id }
                if (!s) return null
                def sub = s.publish_subdir ? "${s.publish_subdir}/" : ''
                "${s.sample}/${sub}profiling/aap/${id}/${rest}"
            }
        ]
    }
}
